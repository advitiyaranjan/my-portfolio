{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Serverless Portfolio Website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "node dev-server.js",
    "dev:client": "cd Client && npm run dev",
    "dev:client-only": "cd Client && npm run dev",
    "start": "cd Client && npm run preview"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0"
  },
  "keywords": [
    "portfolio",
    "react",
    "serverless",
    "vercel"
  ],
  "author": "Advitiya Ranjan",
  "engines": {
    "node": "22.x"
  }
}
