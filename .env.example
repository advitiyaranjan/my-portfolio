# Environment Variables Example
# Copy this file to .env and update the values

# JWT Secret Key - MUST be at least 32 characters for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345678

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# For Vercel Deployment:
# 1. Set JWT_SECRET as environment variable: vercel env add JWT_SECRET
# 2. Use strong secret (32+ chars): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
