{
  "version": 2,
  "buildCommand": "npm install && npm install --include=dev --prefix Client",
  "public": true,
  "outputDirectory": "Client/dist",
  "functions": {
    "api/[...path].js": {
      "runtime": "nodejs20.x",
      "memory": 256,
      "maxDuration": 10
    }
  },
  "env": {
    "JWT_SECRET": {
      "description": "Secret key for JWT tokens"
    },
    "NODE_ENV": {
      "description": "Environment mode"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
